

<!Docktype html>
<html>
<head>
<title> Student registration </title>
<style>
h2{
color: black;
}
</style>
</head>
<body style="background-color: violet;">

<h2>Student registration form<h2>
<form>
<label for="fullname">Full Name:</label><br>
<input type="text" id="student name required"><br><br>
<label for="Email">Email:</label><br>
<input type="text" id="email"><br><br>
<label for="Password">Password:</label><br>
<input type="text" id="password"><br><br>
<label for="DOB">DOB:</label><br>
<input type="text" id="DOB"><br><br>
<label>Gender:</label><br>
<input type="radio" name="gender" value="male">Male
<input type="radio" name="gender" value="female">Female
<input type="radio" name="gender" value="others">others<br><br>
<label>Course:</label><br>
<input type="checkbox" name="course" value="CSE">CSE
<input type="checkbox" name="course" value="IT">IT
<input type="checkbox" name="course" value="ECE">ECE
<input type="checkbox" name="course" value="Mechanical">Mechanical<br><br>
<label>Select Country:</label><br>
<select id="country" name="country">
<option value="">--Select--</option>
<option value="India">India</option>
<option value="UK">UK</option>
<option value="Canada">Canada</option>
</select><br><br>

<!--Adress-->
<label for="Adress">Adress:</label><br>
<textarea id="address" name="address" rows="4" cols="30"></textarea><br><br>

<!--Buttons-->
<input type="submit" value="submit">
<input type="Reset" value="Reset">
</form>
</body>
</html>


