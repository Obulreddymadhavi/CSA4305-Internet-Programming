<!DOCTYPE html>
<html>
<head>
    <title>Number Greater Than 100 Divisible by 99</title>
</head>
<body>

<h2>Number Greater Than 100 Divisible by 99</h2>

<script>
let n = 101;

while (n % 99 != 0) {
    n++;
}

document.write("The first number greater than 100 divisible by 99 is: " + n);
</script>

</body>
</html>
